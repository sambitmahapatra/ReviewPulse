# Copy this file to `.streamlit/secrets.toml` for local testing,
# or paste the same contents into Streamlit Community Cloud > Advanced settings > Secrets.
#
# ReviewPulse supports two deployment patterns:
# 1. Platform-managed LLM mode:
#    Set PLATFORM_LLM_PROVIDER and either PLATFORM_LLM_API_KEY
#    or the matching provider key below.
# 2. Provider-key fallback:
#    Set GROQ_API_KEY or OPENAI_API_KEY only.

PLATFORM_LLM_PROVIDER = "groq"
PLATFORM_LLM_MODEL = "llama-3.3-70b-versatile"
PLATFORM_LLM_API_KEY = "your_platform_managed_llm_key"

# Optional direct provider keys. If PLATFORM_LLM_* is not set,
# the app will use one of these as the backend-managed key.
GROQ_API_KEY = ""
OPENAI_API_KEY = ""
